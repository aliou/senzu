{
  "name": "Senzu Muted",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#101010",
    "editor.foreground": "#dad6c8",
    "editorLineNumber.foreground": "#58534f",
    "editorLineNumber.activeForeground": "#c2bdb8",
    "editor.selectionBackground": "#3c3b38",
    "editor.selectionForeground": "#dad6c8",
    "editorCursor.foreground": "#a6c3d9",
    "terminal.ansiBlack": "#101010",
    "terminal.ansiRed": "#cc4d4d",
    "terminal.ansiGreen": "#909c6e",
    "terminal.ansiYellow": "#e8c88c",
    "terminal.ansiBlue": "#7a8aa6",
    "terminal.ansiMagenta": "#b8aed3",
    "terminal.ansiCyan": "#617b87",
    "terminal.ansiWhite": "#dad6c8",
    "terminal.ansiBrightBlack": "#7a7a7a",
    "terminal.ansiBrightRed": "#7e2e23",
    "terminal.ansiBrightGreen": "#98b67c",
    "terminal.ansiBrightYellow": "#d8a16c",
    "terminal.ansiBrightBlue": "#83adc3",
    "terminal.ansiBrightMagenta": "#5c1e68",
    "terminal.ansiBrightCyan": "#7db7cc",
    "terminal.ansiBrightWhite": "#f9f5ec"
  },
  "tokenColors": [
    {
      "name": "Default foreground and background",
      "settings": {
        "foreground": "#dad6c8",
        "background": "#101010"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a7a7a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation comments",
      "scope": [
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#bebebe"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c88a77"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#c88a77"
      }
    },
    {
      "name": "Booleans / language constants",
      "scope": [
        "constant.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#c88a77"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#909c6e"
      }
    },
    {
      "name": "String escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#bebebe"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#d8a16c"
      }
    },
    {
      "name": "Interpolated / special strings",
      "scope": [
        "string.interpolated",
        "string.template",
        "string.other"
      ],
      "settings": {
        "foreground": "#b8aed3"
      }
    },
    {
      "name": "Symbols",
      "scope": [
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#909c6e"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#e8c88c"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function"
      ],
      "settings": {
        "foreground": "#c88a77"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#7a8aa6"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#83adc3"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.type.class",
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#d8a16c"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#dad6c8"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#dad6c8"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#909c6e"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#83adc3"
      }
    },
    {
      "name": "Namespaces",
      "scope": [
        "entity.name.namespace",
        "support.namespace"
      ],
      "settings": {
        "foreground": "#83adc3"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#dad6c8"
      }
    },
    {
      "name": "Brackets",
      "scope": [
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#dad6c8"
      }
    },
    {
      "name": "Delimiters",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.delimiter"
      ],
      "settings": {
        "foreground": "#dad6c8"
      }
    },
    {
      "name": "List markers",
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#dad6c8"
      }
    },
    {
      "name": "Special punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#dad6c8"
      }
    },
    {
      "name": "Embedded punctuation",
      "scope": [
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#909c6e"
      }
    },
    {
      "name": "Links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title"
      ],
      "settings": {
        "foreground": "#909c6e",
        "fontStyle": "italic underline"
      }
    },
    {
      "name": "Link URIs",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#b8aed3",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Emphasis",
      "scope": [
        "markup.italic",
        "emphasis"
      ],
      "settings": {
        "foreground": "#83adc3",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strong emphasis",
      "scope": [
        "markup.bold",
        "strong"
      ],
      "settings": {
        "foreground": "#83adc3",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#e8c88c",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Inline code / literals",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#83adc3"
      }
    },
    {
      "name": "Preprocessors",
      "scope": [
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#dad6c8"
      }
    },
    {
      "name": "Enums",
      "scope": [
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#d8a16c"
      }
    }
  ]
}

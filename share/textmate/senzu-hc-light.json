{
  "name": "Senzu HC Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#fafafa",
    "editor.foreground": "#000000",
    "editorLineNumber.foreground": "#605958",
    "editorLineNumber.activeForeground": "#404040",
    "editor.selectionBackground": "#e8d0c0",
    "editor.selectionForeground": "#000000",
    "editorCursor.foreground": "#0a3a8a",
    "terminal.ansiBlack": "#f5f5f5",
    "terminal.ansiRed": "#c00000",
    "terminal.ansiGreen": "#507020",
    "terminal.ansiYellow": "#7a5000",
    "terminal.ansiBlue": "#1a3a80",
    "terminal.ansiMagenta": "#4a2090",
    "terminal.ansiCyan": "#306070",
    "terminal.ansiWhite": "#000000",
    "terminal.ansiBrightBlack": "#404040",
    "terminal.ansiBrightRed": "#8a1010",
    "terminal.ansiBrightGreen": "#1f5d10",
    "terminal.ansiBrightYellow": "#8a5000",
    "terminal.ansiBrightBlue": "#0a4a7a",
    "terminal.ansiBrightMagenta": "#600080",
    "terminal.ansiBrightCyan": "#0a4a7a",
    "terminal.ansiBrightWhite": "#505050"
  },
  "tokenColors": [
    {
      "name": "Default foreground and background",
      "settings": {
        "foreground": "#000000",
        "background": "#fafafa"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#404040",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation comments",
      "scope": [
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#505050"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#8a3a10"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#8a3a10"
      }
    },
    {
      "name": "Booleans / language constants",
      "scope": [
        "constant.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#8a3a10"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#507020"
      }
    },
    {
      "name": "String escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#606060"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#8a5000"
      }
    },
    {
      "name": "Interpolated / special strings",
      "scope": [
        "string.interpolated",
        "string.template",
        "string.other"
      ],
      "settings": {
        "foreground": "#4a2090"
      }
    },
    {
      "name": "Symbols",
      "scope": [
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#507020"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#7a5000"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function"
      ],
      "settings": {
        "foreground": "#8a3a10"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#1a3a80"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#0a4a7a"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.type.class",
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#8a5000"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#507020"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#0a4a7a"
      }
    },
    {
      "name": "Namespaces",
      "scope": [
        "entity.name.namespace",
        "support.namespace"
      ],
      "settings": {
        "foreground": "#0a4a7a"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Brackets",
      "scope": [
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Delimiters",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.delimiter"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "List markers",
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Special punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Embedded punctuation",
      "scope": [
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#507020"
      }
    },
    {
      "name": "Links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title"
      ],
      "settings": {
        "foreground": "#507020",
        "fontStyle": "italic underline"
      }
    },
    {
      "name": "Link URIs",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#4a2090",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Emphasis",
      "scope": [
        "markup.italic",
        "emphasis"
      ],
      "settings": {
        "foreground": "#0a4a7a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strong emphasis",
      "scope": [
        "markup.bold",
        "strong"
      ],
      "settings": {
        "foreground": "#0a4a7a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#7a5000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Inline code / literals",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#0a4a7a"
      }
    },
    {
      "name": "Preprocessors",
      "scope": [
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Enums",
      "scope": [
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#8a5000"
      }
    }
  ]
}

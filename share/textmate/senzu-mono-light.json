{
  "name": "Senzu Mono Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#f5f0e8",
    "editor.foreground": "#252525",
    "editorLineNumber.foreground": "#605958",
    "editorLineNumber.activeForeground": "#6a6564",
    "editor.selectionBackground": "#d8c8b8",
    "editor.selectionForeground": "#252525",
    "editorCursor.foreground": "#4a5e81",
    "terminal.ansiBlack": "#f5f5f5",
    "terminal.ansiRed": "#cc0000",
    "terminal.ansiGreen": "#7d7163",
    "terminal.ansiYellow": "#6a6564",
    "terminal.ansiBlue": "#4a5e81",
    "terminal.ansiMagenta": "#555555",
    "terminal.ansiCyan": "#576270",
    "terminal.ansiWhite": "#252525",
    "terminal.ansiBrightBlack": "#787878",
    "terminal.ansiBrightRed": "#ffe5ea",
    "terminal.ansiBrightGreen": "#3d6c25",
    "terminal.ansiBrightYellow": "#707070",
    "terminal.ansiBrightBlue": "#4a5e81",
    "terminal.ansiBrightMagenta": "#909090",
    "terminal.ansiBrightCyan": "#645c54",
    "terminal.ansiBrightWhite": "#000000"
  },
  "tokenColors": [
    {
      "name": "Default foreground and background",
      "settings": {
        "foreground": "#252525",
        "background": "#f5f0e8"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#909090",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation comments",
      "scope": [
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#555555"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#7d7163"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#7d7163"
      }
    },
    {
      "name": "Booleans / language constants",
      "scope": [
        "constant.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#7d7163"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#796858"
      }
    },
    {
      "name": "String escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#555555"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#7d7163"
      }
    },
    {
      "name": "Interpolated / special strings",
      "scope": [
        "string.interpolated",
        "string.template",
        "string.other"
      ],
      "settings": {
        "foreground": "#555555"
      }
    },
    {
      "name": "Symbols",
      "scope": [
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#796858"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#4a5e81"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function"
      ],
      "settings": {
        "foreground": "#7d7163"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#787878"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#4a5e81"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.type.class",
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#7d7163"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#252525"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#252525"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#796858"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4a5e81"
      }
    },
    {
      "name": "Namespaces",
      "scope": [
        "entity.name.namespace",
        "support.namespace"
      ],
      "settings": {
        "foreground": "#4a5e81"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#252525"
      }
    },
    {
      "name": "Brackets",
      "scope": [
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#252525"
      }
    },
    {
      "name": "Delimiters",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.delimiter"
      ],
      "settings": {
        "foreground": "#252525"
      }
    },
    {
      "name": "List markers",
      "scope": [
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#252525"
      }
    },
    {
      "name": "Special punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#252525"
      }
    },
    {
      "name": "Embedded punctuation",
      "scope": [
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#796858"
      }
    },
    {
      "name": "Links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title"
      ],
      "settings": {
        "foreground": "#796858",
        "fontStyle": "italic underline"
      }
    },
    {
      "name": "Link URIs",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#555555",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Emphasis",
      "scope": [
        "markup.italic",
        "emphasis"
      ],
      "settings": {
        "foreground": "#4a5e81",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strong emphasis",
      "scope": [
        "markup.bold",
        "strong"
      ],
      "settings": {
        "foreground": "#4a5e81",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#4a5e81",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Inline code / literals",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#4a5e81"
      }
    },
    {
      "name": "Preprocessors",
      "scope": [
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#252525"
      }
    },
    {
      "name": "Enums",
      "scope": [
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#7d7163"
      }
    }
  ]
}
